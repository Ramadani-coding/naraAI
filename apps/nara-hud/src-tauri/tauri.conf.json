{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NARA",
  "version": "0.1.2",
  "identifier": "ai.nara.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": false,
    "windows": [
      {
        "label": "main",
        "title": "NARA",
        "width": 1320,
        "height": 860,
        "minWidth": 980,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "msi"],
    "category": "DeveloperTool",
    "shortDescription": "Windows AI desktop assistant",
    "longDescription": "NARA is a Windows-first AI desktop assistant with HUD, voice, Codex, approvals, and local tools."
  }
}
